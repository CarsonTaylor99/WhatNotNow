# ─────────────────────────────────────────────────────────────
#  HOW TO FILL THIS IN
#  1. Open whatnot.com in your browser, log in
#  2. Open DevTools (F12) → Network tab → click any request to whatnot.com
#     Headers → Request Headers → find "Cookie" → paste the whole value below
#  3. Open a live stream → DevTools → Network → WS filter
#     Click the auction socket → copy _csrf_token and sessionExtensionToken from the URL
#
#  NOTE: These tokens expire with your session. Re-paste when the scanner stops connecting.
# ─────────────────────────────────────────────────────────────

WHATNOT_COOKIE=paste_your_full_cookie_string_here

WHATNOT_CSRF_TOKEN=paste_csrf_token_from_ws_url_here

WHATNOT_SESSION_TOKEN=paste_sessionExtensionToken_from_ws_url_here

# How many seconds to listen per stream before moving on (10-30 recommended)
SCAN_DURATION=15
